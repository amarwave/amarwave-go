# AmarWave Go Server SDK — Environment Variables
# Copy this file to .env and load it before running your server.
# All variables are optional; hardcoded defaults are shown.

# AmarWave HTTP API hostname
AMARWAVE_HOST=localhost

# AmarWave HTTP API port
AMARWAVE_PORT=8000

# Set to "true" to use HTTPS
AMARWAVE_SSL=false

# HTTP API trigger path (change only if you customised the server route)
AMARWAVE_API_PATH=/api/v1/trigger
